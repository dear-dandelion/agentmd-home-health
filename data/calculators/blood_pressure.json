      {
        "name": "elevated_lower_bound",
        "input": { "systolic_bp": 120, "diastolic_bp": 79 },
        "expected_risk_level": "偏高"
      },
      {
        "name": "elevated_upper_bound",
        "input": { "systolic_bp": 139, "diastolic_bp": 89 },
        "expected_risk_level": "偏高"
      },
      {
        "name": "high_risk_lower_bound",
        "input": { "systolic_bp": 140, "diastolic_bp": 90 },
        "expected_risk_level": "高风险"
